-- Precision Aim Target Acquisition Function
local function getClosestPlayerToCrosshair()
	local closestPlayer = nil
	local shortestDistance = aimFovRadius
	local mousePos = UserInputService:GetMouseLocation()

	for _, p in pairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
			local head = p.Character.Head
			local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
			
			if onScreen then
				local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
				if distance < shortestDistance then
					shortestDistance = distance; closestPlayer = p
				end
			end
		end
	end
	return closestPlayer
end

local function isAimBindPressed()
	if aimInputType == Enum.UserInputType.Keyboard and aimKeyCode then
		return UserInputService:IsKeyDown(aimKeyCode)
	else
		return UserInputService:IsMouseButtonPressed(aimInputType)
	end
end

-- Core Aim Assist
RunService.RenderStepped:Connect(function()
	if aimAssistEnabled and isAimBindPressed() then
		local targetPlayer = getClosestPlayerToCrosshair()
		if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head") then
			local targetHead = targetPlayer.Character.Head
			camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, targetHead.Position), 1 / aimStrength)
		end
	end
end)

-- --- CONSTANT ACTIVE HITBOX SCANNER ENGINE ---
RunService.RenderStepped:Connect(function()
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") then
			local hrp = p.Character.HumanoidRootPart
			local humanoid = p.Character:FindFirstChildOfClass("Humanoid")
			
			if humanoid.Health > 0 then
				if not originalPartSizes[p.Name] then
					originalPartSizes[p.Name] = hrp.Size
				end

				local boxAdorn = hrp:FindFirstChild("WildHitboxVisual")
				if showHitboxVisuals and hitboxExpanderEnabled then
					if not boxAdorn then
						boxAdorn = Instance.new("BoxHandleAdornment")
						boxAdorn.Name = "WildHitboxVisual"
						boxAdorn.AlwaysOnTop = true
						boxAdorn.ZIndex = 5
						boxAdorn.Adornee = hrp
						boxAdorn.Parent = hrp
					end
					boxAdorn.Size = hrp.Size
					boxAdorn.Color3 = hitboxColor
					boxAdorn.Transparency = 0.6
				else
					if boxAdorn then boxAdorn:Destroy() end
				end

				if hitboxExpanderEnabled then
					hrp.Size = Vector3.new(hitboxSizeValue, hitboxSizeValue, hitboxSizeValue)
					hrp.CanCollide = false
					hrp.Transparency = showHitboxVisuals and 1 or 0
				else
					if originalPartSizes[p.Name] then
						hrp.Size = originalPartSizes[p.Name]
						hrp.Transparency = 0
					end
				end
			end
		end
	end
end)

