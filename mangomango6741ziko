	colorLabel.Parent = parent

	local spectrumFrame = Instance.new("ImageButton")
	spectrumFrame.Size = UDim2.new(1, -150, 0, 22)
	spectrumFrame.Position = UDim2.new(0, 135, 0, yPos + 2)
	spectrumFrame.Image = "rbxassetid://3641079629"
	spectrumFrame.ScaleType = Enum.ScaleType.Stretch
	spectrumFrame.Parent = parent
	Instance.new("UICorner", spectrumFrame).CornerRadius = UDim.new(0, 4)

	local indicator = Instance.new("Frame")
	indicator.Size = UDim2.new(0, 8, 1, 4)
	indicator.Position = UDim2.new(0.5, -4, 0, -2)
	indicator.BackgroundColor3 = defaultColor
	indicator.BorderSizePixel = 1
	indicator.Parent = spectrumFrame
	Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 3)

	local activeSliding = false
	local function updateWheelColor(input)
		local relativeX = math.clamp((input.Position.X - spectrumFrame.AbsolutePosition.X) / spectrumFrame.AbsoluteSize.X, 0, 1)
		indicator.Position = UDim2.new(relativeX, -4, 0, -2)
		local generatedColor = Color3.fromHSV(relativeX, 0.9, 1)
		indicator.BackgroundColor3 = generatedColor
		callback(generatedColor)
	end
	spectrumFrame.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then activeSliding = true; updateWheelColor(input) end end)
	UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then activeSliding = false end end)
	UserInputService.InputChanged:Connect(function(input) if activeSliding and input.UserInputType == Enum.UserInputType.MouseMovement then updateWheelColor(input) end end)
end

